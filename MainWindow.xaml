<Window x:Class="MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="🔐 Mavicks — Cybersecurity Awareness Assistant"
        Height="850" Width="1100"
        MinHeight="600" MinWidth="900"
        WindowStartupLocation="CenterScreen"
        Background="#0d0d1a">

    <Window.Resources>

        <SolidColorBrush x:Key="BgDeep"        Color="#0d0d1a"/>
        <SolidColorBrush x:Key="BgPanel"       Color="#12122a"/>
        <SolidColorBrush x:Key="BgInput"       Color="#1a1a35"/>
        <SolidColorBrush x:Key="AccentCyan"    Color="#00e5ff"/>
        <SolidColorBrush x:Key="AccentGreen"   Color="#00e676"/>
        <SolidColorBrush x:Key="AccentYellow"  Color="#ffd600"/>
        <SolidColorBrush x:Key="AccentAmber"   Color="#ffab00"/>
        <SolidColorBrush x:Key="TextMuted"     Color="#607d8b"/>
        <SolidColorBrush x:Key="TextWhite"     Color="#e0e0e0"/>
        <SolidColorBrush x:Key="BorderColour"  Color="#1e3a5f"/>

        <!-- SEND BUTTON STYLE -->
        <Style x:Key="SendButtonStyle" TargetType="Button">
            <Setter Property="Background"   Value="#00e5ff"/>
            <Setter Property="Foreground"   Value="#0d0d1a"/>
            <Setter Property="FontFamily"   Value="Consolas"/>
            <Setter Property="FontSize"     Value="14"/>
            <Setter Property="FontWeight"   Value="Bold"/>
            <Setter Property="Padding"      Value="20,8"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor"       Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="6"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#00b8d4"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" Value="#006064"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Background" Value="#37474f"/>
                                <Setter Property="Foreground" Value="#607d8b"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- INPUT TEXTBOX STYLE — fixed vertical centering -->
        <Style x:Key="InputBoxStyle" TargetType="TextBox">
            <Setter Property="Background"       Value="#1a1a35"/>
            <Setter Property="Foreground"       Value="#e0e0e0"/>
            <Setter Property="CaretBrush"       Value="#00e5ff"/>
            <Setter Property="FontFamily"       Value="Consolas"/>
            <Setter Property="FontSize"         Value="15"/>
            <Setter Property="BorderBrush"      Value="#1e3a5f"/>
            <Setter Property="BorderThickness"  Value="1"/>
            <Setter Property="Padding"          Value="12,0"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border x:Name="border"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6">
                            <!-- Grid centres the ScrollViewer vertically -->
                            <Grid>
                                <ScrollViewer x:Name="PART_ContentHost"
                                              Margin="{TemplateBinding Padding}"
                                              VerticalAlignment="Center"
                                              VerticalScrollBarVisibility="Hidden"
                                              HorizontalScrollBarVisibility="Hidden"/>
                            </Grid>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsFocused" Value="True">
                                <Setter TargetName="border" Property="BorderBrush" Value="#00e5ff"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ComboBoxStyle" TargetType="ComboBox">
            <Setter Property="Background" Value="#1a1a35"/>
            <Setter Property="Foreground" Value="#e0e0e0"/>
            <Setter Property="BorderBrush" Value="#1e3a5f"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="FontFamily" Value="Consolas"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Padding" Value="8,4"/>
        </Style>

    </Window.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="280"/>
        </Grid.ColumnDefinitions>

        <!-- MAIN CHAT COLUMN -->
        <Grid Grid.Column="0">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- ROW 0 — HEADER -->
        <Border Grid.Row="0"
                Background="#12122a"
                BorderBrush="#1e3a5f"
                BorderThickness="0,0,0,1"
                Padding="16,12">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0"
                           x:Name="BannerTextBlock"
                           FontFamily="Consolas"
                           FontSize="11"
                           Foreground="#00e5ff"
                           VerticalAlignment="Center"
                           Margin="0,0,16,0"
                           TextWrapping="NoWrap"/>
                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                    <TextBlock Text="🔐 MAVICKS"
                               FontFamily="Consolas"
                               FontSize="22"
                               FontWeight="Bold"
                               Foreground="#00e5ff"/>
                    <TextBlock Text="Cybersecurity Awareness Assistant"
                               FontFamily="Consolas"
                               FontSize="12"
                               Foreground="#607d8b"
                               Margin="0,2,0,0"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ROW 1 — CHAT AREA -->
        <ScrollViewer Grid.Row="1"
                      x:Name="ChatScrollViewer"
                      VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled"
                      Background="#0d0d1a"
                      Padding="16,12">
            <StackPanel x:Name="ChatPanel" Orientation="Vertical"/>
        </ScrollViewer>

        <!-- ROW 2 — CONVERSATION SUGGESTIONS -->
        <Border Grid.Row="2"
                Background="#0d0d1a"
                BorderBrush="#1e3a5f"
                BorderThickness="0,1,0,0"
                Padding="16,8">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                <TextBlock Text="💬 Quick Topics: " Foreground="#607d8b" FontSize="11" FontFamily="Consolas" VerticalAlignment="Center" Margin="0,0,8,0"/>
                <Button x:Name="SuggestionPasswordBtn" Content="🔐 Password Safety" Background="Transparent" Foreground="#00e5ff" Cursor="Hand" Click="SuggestionButton_Click" Tag="password" Padding="4,0" Margin="0,0,6,0" FontFamily="Consolas" FontSize="10"/>
                <Button Content="🎣 Phishing" Background="Transparent" Foreground="#00e676" Cursor="Hand" Click="SuggestionButton_Click" Tag="phishing" Padding="4,0" Margin="0,0,6,0" FontFamily="Consolas" FontSize="10"/>
                <Button Content="🛡️ Privacy" Background="Transparent" Foreground="#ffab00" Cursor="Hand" Click="SuggestionButton_Click" Tag="privacy" Padding="4,0" Margin="0,0,6,0" FontFamily="Consolas" FontSize="10"/>
                <Button Content="📊 Stats" Background="Transparent" Foreground="#00b8d4" Cursor="Hand" Click="SuggestionButton_Click" Tag="statistics" Padding="4,0" Margin="0,0,6,0" FontFamily="Consolas" FontSize="10"/>
                <Button Content="📖 Help" Background="Transparent" Foreground="#a0a0a0" Cursor="Hand" Click="SuggestionButton_Click" Tag="help" Padding="4,0" FontFamily="Consolas" FontSize="10"/>
            </StackPanel>
        </Border>

        <!-- ROW 3 — INPUT BAR -->
        <Border Grid.Row="3"
                Background="#12122a"
                BorderBrush="#1e3a5f"
                BorderThickness="0,1,0,0"
                Padding="16,10">
            <StackPanel>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <TextBox Grid.Column="0"
                             x:Name="UserInputBox"
                             Style="{StaticResource InputBoxStyle}"
                             Height="52"
                             Margin="0,0,10,0"
                             IsEnabled="False"
                             KeyDown="UserInputBox_KeyDown"
                             ToolTip="Type your message and press Enter or click Send"/>

                    <Button Grid.Column="1"
                            x:Name="SendButton"
                            Content="Send"
                            Style="{StaticResource SendButtonStyle}"
                            Height="52"
                            IsEnabled="False"
                            Margin="0,0,10,0"
                            Click="SendButton_Click"/>

                    <Button Grid.Column="2"
                            x:Name="ClearButton"
                            Content="Clear"
                            Style="{StaticResource SendButtonStyle}"
                            Height="52"
                            Background="#37474f"
                            Foreground="#e0e0e0"
                            Click="ClearButton_Click"/>
                </Grid>

                <TextBlock Text="💡 Tip: Ask about cybersecurity topics or use 'help' command"
                           FontFamily="Consolas"
                           FontSize="11"
                           Foreground="#607d8b"
                           Margin="0,10,0,0"
                           TextWrapping="Wrap"/>
            </StackPanel>
        </Border>

        <!-- NAME PROMPT OVERLAY -->
        <Grid Grid.Row="0"
              Grid.RowSpan="4"
              x:Name="NamePromptOverlay"
              Background="#CC0d0d1a"
              Visibility="Visible">

            <Border HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Background="#12122a"
                    BorderBrush="#00e5ff"
                    BorderThickness="1"
                    CornerRadius="10"
                    Padding="40,32"
                    MinWidth="400">
                <StackPanel>
                    <TextBlock Text="🔐"
                               FontSize="48"
                               HorizontalAlignment="Center"
                               Margin="0,0,0,8"/>
                    <TextBlock Text="Welcome to Mavicks"
                               FontFamily="Consolas"
                               FontSize="20"
                               FontWeight="Bold"
                               Foreground="#00e5ff"
                               HorizontalAlignment="Center"/>
                    <TextBlock Text="Cybersecurity Awareness Assistant"
                               FontFamily="Consolas"
                               FontSize="12"
                               Foreground="#607d8b"
                               HorizontalAlignment="Center"
                               Margin="0,4,0,24"/>

                    <TextBlock Text="Please enter your name to begin:"
                               FontFamily="Consolas"
                               FontSize="13"
                               Foreground="#e0e0e0"
                               Margin="0,0,0,8"/>

                    <TextBox x:Name="NameInputBox"
                             Style="{StaticResource InputBoxStyle}"
                             Height="52"
                             Margin="0,0,0,8"
                             KeyDown="NameInputBox_KeyDown"/>

                    <TextBlock x:Name="NameErrorLabel"
                               FontFamily="Consolas"
                               FontSize="12"
                               Foreground="#ff5252"
                               Visibility="Collapsed"
                               Margin="0,0,0,8"
                               TextWrapping="Wrap"/>

                    <Button x:Name="StartButton"
                            Content="Start Chat  →"
                            Style="{StaticResource SendButtonStyle}"
                            Height="46"
                            Click="StartButton_Click"/>
                </StackPanel>
            </Border>
        </Grid>

        </Grid>

        <!-- SIDEBAR — TASKS & QUICK ACTIONS -->
        <Border Grid.Column="1"
                Background="#12122a"
                BorderBrush="#1e3a5f"
                BorderThickness="1,0,0,0"
                Padding="12">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0"
                           Text="📋 Task Assistant"
                           FontFamily="Consolas"
                           FontSize="14"
                           FontWeight="Bold"
                           Foreground="#00e5ff"
                           Margin="0,0,0,8"/>

                <TextBlock Grid.Row="1"
                           x:Name="DbStatusTextBlock"
                           Text="Database: checking..."
                           FontFamily="Consolas"
                           FontSize="10"
                           Foreground="#607d8b"
                           TextWrapping="Wrap"
                           Margin="0,0,0,10"/>

                <Border Grid.Row="2"
                        Background="#14142f"
                        BorderBrush="#1e3a5f"
                        BorderThickness="1"
                        CornerRadius="8"
                        Padding="10"
                        Margin="0,0,0,8">
                    <StackPanel Orientation="Vertical">
                                <TextBlock Text="Search &amp; filter tasks"
                                   FontFamily="Consolas"
                                   FontSize="12"
                                   Foreground="#e0e0e0"
                                   FontWeight="Bold"
                                   Margin="0,0,0,8"/>
                        <TextBox x:Name="TaskSearchTextBox"
                                 Style="{StaticResource InputBoxStyle}"
                                 Height="34"
                                 FontSize="12"
                                 ToolTip="Search tasks by title or description"
                                 Margin="0,0,0,8"
                                 TextChanged="TaskSearchTextBox_TextChanged"/>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                            <ComboBox x:Name="TaskFilterComboBox"
                                      Style="{StaticResource ComboBoxStyle}"
                                      Width="130"
                                      FontSize="12"
                                      SelectedIndex="0"
                                      SelectionChanged="TaskFilterComboBox_SelectionChanged"
                                      Margin="0,0,8,0">
                                <ComboBoxItem Content="All"/>
                                <ComboBoxItem Content="Pending"/>
                                <ComboBoxItem Content="Completed"/>
                                <ComboBoxItem Content="Due Today"/>
                                <ComboBoxItem Content="High Priority"/>
                            </ComboBox>
                            <ComboBox x:Name="TaskSortComboBox"
                                      Style="{StaticResource ComboBoxStyle}"
                                      Width="140"
                                      FontSize="12"
                                      SelectedIndex="0"
                                      SelectionChanged="TaskSortComboBox_SelectionChanged">
                                <ComboBoxItem Content="Newest first"/>
                                <ComboBoxItem Content="Oldest first"/>
                                <ComboBoxItem Content="Alphabetical"/>
                                <ComboBoxItem Content="Due date"/>
                            </ComboBox>
                        </StackPanel>
                        <Button x:Name="ExportTasksButton"
                                Content="Export tasks"
                                Style="{StaticResource SendButtonStyle}"
                                Height="34"
                                Click="ExportTasksButton_Click"/>
                    </StackPanel>
                </Border>

                <Border Grid.Row="3"
                        Background="#14142f"
                        BorderBrush="#1e3a5f"
                        BorderThickness="1"
                        CornerRadius="8"
                        Padding="10"
                        Margin="0,0,0,8">
                    <StackPanel Orientation="Vertical">
                        <TextBlock Text="Add or edit cybersecurity task"
                                   FontFamily="Consolas"
                                   FontSize="12"
                                   Foreground="#e0e0e0"
                                   FontWeight="Bold"
                                   Margin="0,0,0,8"/>
                        <TextBox x:Name="NewTaskTitleTextBox"
                                 Style="{StaticResource InputBoxStyle}"
                                 Height="38"
                                 FontSize="12"
                                 ToolTip="Task title (e.g. Update password)"
                                 Margin="0,0,0,8"/>
                        <TextBox x:Name="NewTaskDescriptionTextBox"
                                 Style="{StaticResource InputBoxStyle}"
                                 Height="60"
                                 FontSize="12"
                                 TextWrapping="Wrap"
                                 AcceptsReturn="True"
                                 VerticalScrollBarVisibility="Auto"
                                 ToolTip="Task description"
                                 Margin="0,0,0,8"/>
                        <DatePicker x:Name="NewTaskReminderDatePicker"
                                    Height="38"
                                    FontSize="12"
                                    ToolTip="Reminder date"
                                    Margin="0,0,0,8"/>
                        <TextBox x:Name="NewTaskDueDateTextBox"
                                 Style="{StaticResource InputBoxStyle}"
                                 Height="38"
                                 FontSize="12"
                                 ToolTip="Optional due date (e.g. 2026-08-31 or tomorrow)"
                                 Margin="0,0,0,8"/>
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Left">
                            <Button x:Name="AddTaskButton"
                                    Content="+ Add Task"
                                    Style="{StaticResource SendButtonStyle}"
                                    Height="36"
                                    Width="120"
                                    Margin="0,0,8,0"
                                    Click="AddTaskButton_Click"/>
                            <Button x:Name="EditTaskButton"
                                    Content="✎ Edit Task"
                                    Style="{StaticResource SendButtonStyle}"
                                    Height="36"
                                    Width="120"
                                    Background="#00b8d4"
                                    Foreground="#ffffff"
                                    Click="EditTaskButton_Click"/>
                        </StackPanel>
                    </StackPanel>
                </Border>

                    <DataGrid x:Name="TasksDataGrid"
                              Background="#0d0d1a"
                              BorderBrush="#1e3a5f"
                              BorderThickness="1"
                              Foreground="#e0e0e0"
                              FontFamily="Consolas"
                              FontSize="11"
                              SelectionMode="Single"
                              SelectionUnit="FullRow"
                              AutoGenerateColumns="False"
                              CanUserAddRows="False"
                              IsReadOnly="True"
                              Margin="0,0,0,8">
                        <DataGrid.RowStyle>
                            <Style TargetType="DataGridRow">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsCompleted}" Value="True">
                                        <Setter Property="Background" Value="#2e3d2f"/>
                                        <Setter Property="Foreground" Value="#d7f5dc"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </DataGrid.RowStyle>
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="ID" Binding="{Binding Id}" Width="30"/>
                            <DataGridTextColumn Header="Task" Binding="{Binding Title}" Width="120"/>
                            <DataGridTextColumn Header="Priority" Binding="{Binding PriorityDisplay}" Width="70"/>
                            <DataGridTextColumn Header="Category" Binding="{Binding CategoryDisplay}" Width="80"/>
                            <DataGridTextColumn Header="Status" Binding="{Binding StatusDisplay}" Width="70"/>
                            <DataGridTextColumn Header="Reminder" Binding="{Binding ReminderDisplay}" Width="100"/>
                            <DataGridTextColumn Header="Due" Binding="{Binding DueDisplay}" Width="100"/>
                        </DataGrid.Columns>
                    </DataGrid>

                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Left">
                        <Button x:Name="CompleteTaskButton"
                                Content="✔ Complete"
                                Style="{StaticResource SendButtonStyle}"
                                Height="36"
                                Width="120"
                                Margin="0,0,8,0"
                                Click="CompleteTaskButton_Click"/>
                        <Button x:Name="DeleteTaskButton"
                                Content="🗑 Delete"
                                Style="{StaticResource SendButtonStyle}"
                                Height="36"
                                Width="120"
                                Background="#ff5252"
                                Foreground="#ffffff"
                                Click="DeleteTaskButton_Click"/>
                    </StackPanel>
                

                <TextBlock Grid.Row="3"
                           x:Name="QuizStatusTextBlock"
                           Text="No quiz in progress"
                           FontFamily="Consolas"
                           FontSize="11"
                           Foreground="#00e676"
                           Margin="0,10,0,8"
                           TextWrapping="Wrap"/>

                <StackPanel Grid.Row="4" Orientation="Vertical">
                    <ProgressBar x:Name="QuizProgressBar"
                                 Height="12"
                                 Minimum="0"
                                 Maximum="1"
                                 Value="0"
                                 Margin="0,0,8,10"
                                 Foreground="#00e676"
                                 Background="#0d0d1a"/>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                        <Button Content="🎮 Start Quiz"
                                Style="{StaticResource SendButtonStyle}"
                                Height="36"
                                Width="120"
                                Margin="0,0,8,0"
                                Click="StartQuizButton_Click"/>
                        <Button Content="↻ Restart Quiz"
                                Style="{StaticResource SendButtonStyle}"
                                Height="36"
                                Width="120"
                                Background="#00b8d4"
                                Foreground="#ffffff"
                                Click="RestartQuizButton_Click"/>
                    </StackPanel>
                    <Button Content="📋 View Tasks"
                            Style="{StaticResource SendButtonStyle}"
                            Height="36"
                            Margin="0,0,0,6"
                            Background="#37474f"
                            Foreground="#e0e0e0"
                            Click="ViewTasksButton_Click"/>
                    <Button Content="📜 Activity Log"
                            Style="{StaticResource SendButtonStyle}"
                            Height="36"
                            Margin="0,0,0,6"
                            Background="#37474f"
                            Foreground="#e0e0e0"
                            Click="ActivityLogButton_Click"/>
                    <Button Content="↻ Refresh Tasks"
                            Style="{StaticResource SendButtonStyle}"
                            Height="36"
                            Background="#1e3a5f"
                            Foreground="#e0e0e0"
                            Click="RefreshTasksButton_Click"/>
                </StackPanel>
            </Grid>
        </Border>

    </Grid>
</Window>
