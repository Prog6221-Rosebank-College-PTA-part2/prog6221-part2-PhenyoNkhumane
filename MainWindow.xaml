<Window x:Class="MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="🔐 Cybersecurity Awareness Assistant"
        Height="900" Width="1250"
        MinHeight="720" MinWidth="1024"
        WindowStartupLocation="CenterScreen"
        Background="{StaticResource SecondaryBlack}">

    <Window.Resources>
        <Style x:Key="SendButtonStyle" TargetType="Button" BasedOn="{StaticResource PrimaryButtonStyle}"/>
        <Style x:Key="InputBoxStyle" TargetType="TextBox" BasedOn="{StaticResource InputBoxStyle}"/>
        <Style x:Key="ComboBoxStyle" TargetType="ComboBox" BasedOn="{StaticResource ComboBoxStyle}"/>
    </Window.Resources>

    <Grid Background="{StaticResource SecondaryBlack}">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="250"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- MAIN CONTENT -->
        <Grid Grid.Column="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <Border Grid.Row="0"
                    Background="{StaticResource SurfaceDark}"
                    BorderBrush="{StaticResource BorderColor}"
                    BorderThickness="0,0,0,1"
                    Padding="24,18">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0"
                               x:Name="BannerTextBlock"
                               FontFamily="Consolas"
                               FontSize="11"
                               Foreground="{StaticResource PrimaryRed}"
                               VerticalAlignment="Center"
                               Margin="0,0,16,0"
                               TextWrapping="NoWrap"/>
                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                        <TextBlock Text="🛡 CYBERSECURITY AWARENESS ASSISTANT"
                                   FontFamily="Segoe UI Semibold"
                                   FontSize="22"
                                   FontWeight="SemiBold"
                                   Foreground="{StaticResource TextPrimary}"/>
                        <TextBlock Text="Professional guidance for phishing, passwords, privacy, and secure habits"
                                   FontFamily="Segoe UI"
                                   FontSize="12"
                                   Foreground="{StaticResource TextSecondary}"
                                   Margin="0,4,0,0"/>
                    </StackPanel>
                </Grid>
            </Border>

            <ScrollViewer Grid.Row="1"
                          x:Name="ChatScrollViewer"
                          VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled"
                          Background="{StaticResource SecondaryBlack}"
                          Padding="20,14">
                <StackPanel x:Name="ChatPanel" Orientation="Vertical"/>
            </ScrollViewer>

            <Border Grid.Row="2"
                    Background="{StaticResource SurfaceDark}"
                    BorderBrush="{StaticResource BorderColor}"
                    BorderThickness="0,1,0,0"
                    Padding="16,10">
                <WrapPanel HorizontalAlignment="Center">
                    <Button x:Name="SuggestionPasswordBtn" Content="🔐 Password Safety" Style="{StaticResource SecondaryButtonStyle}" Click="SuggestionButton_Click" Tag="password" Margin="4"/>
                    <Button Content="🎣 Phishing" Style="{StaticResource SecondaryButtonStyle}" Click="SuggestionButton_Click" Tag="phishing" Margin="4"/>
                    <Button Content="🛡 Privacy" Style="{StaticResource SecondaryButtonStyle}" Click="SuggestionButton_Click" Tag="privacy" Margin="4"/>
                    <Button Content="📊 Statistics" Style="{StaticResource SecondaryButtonStyle}" Click="SuggestionButton_Click" Tag="statistics" Margin="4"/>
                    <Button Content="📖 Help" Style="{StaticResource SecondaryButtonStyle}" Click="SuggestionButton_Click" Tag="help" Margin="4"/>
                </WrapPanel>
            </Border>

            <Border Grid.Row="3"
                    Background="{StaticResource SurfaceDark}"
                    BorderBrush="{StaticResource BorderColor}"
                    BorderThickness="0,1,0,0"
                    Padding="20,14">
                <StackPanel>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <TextBox Grid.Column="0"
                                 x:Name="UserInputBox"
                                 Style="{StaticResource InputBoxStyle}"
                                 Height="48"
                                 Margin="0,0,10,0"
                                 IsEnabled="False"
                                 KeyDown="UserInputBox_KeyDown"
                                 ToolTip="Type your message and press Enter or click Send"/>

                        <Button Grid.Column="1"
                                x:Name="SendButton"
                                Content="Send"
                                Style="{StaticResource SendButtonStyle}"
                                Height="48"
                                Width="100"
                                IsEnabled="False"
                                Margin="0,0,10,0"
                                Click="SendButton_Click"/>

                        <Button Grid.Column="2"
                                x:Name="ClearButton"
                                Content="Clear"
                                Style="{StaticResource SecondaryButtonStyle}"
                                Height="48"
                                Width="90"
                                Click="ClearButton_Click"/>
                    </Grid>

                    <TextBlock Text="Tip: ask about password safety, phishing, privacy, or use the quick actions above"
                               FontFamily="Segoe UI"
                               FontSize="11"
                               Foreground="{StaticResource TextMuted}"
                               Margin="0,10,0,0"
                               TextWrapping="Wrap"/>
                </StackPanel>
            </Border>

            <Grid Grid.Row="0"
                  Grid.RowSpan="4"
                  x:Name="NamePromptOverlay"
                  Background="#CC121212"
                  Visibility="Visible">
                <Border HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        Background="{StaticResource SurfaceDark}"
                        BorderBrush="{StaticResource PrimaryRed}"
                        BorderThickness="1"
                        CornerRadius="18"
                        Padding="34,28"
                        MinWidth="420">
                    <StackPanel>
                        <TextBlock Text="🛡"
                                   FontSize="42"
                                   HorizontalAlignment="Center"
                                   Margin="0,0,0,8"/>
                        <TextBlock Text="Welcome to the Cybersecurity Assistant"
                                   FontFamily="Segoe UI Semibold"
                                   FontSize="22"
                                   FontWeight="SemiBold"
                                   Foreground="{StaticResource TextPrimary}"
                                   HorizontalAlignment="Center"/>
                        <TextBlock Text="Secure your workflow with guided tasks, reminders, and cyber awareness insights"
                                   FontFamily="Segoe UI"
                                   FontSize="12"
                                   Foreground="{StaticResource TextSecondary}"
                                   HorizontalAlignment="Center"
                                   Margin="0,6,0,22"/>

                        <TextBlock Text="Please enter your name to begin:"
                                   FontFamily="Segoe UI"
                                   FontSize="13"
                                   Foreground="{StaticResource TextPrimary}"
                                   Margin="0,0,0,8"/>

                        <TextBox x:Name="NameInputBox"
                                 Style="{StaticResource InputBoxStyle}"
                                 Height="44"
                                 Margin="0,0,0,8"
                                 KeyDown="NameInputBox_KeyDown"/>

                        <TextBlock x:Name="NameErrorLabel"
                                   FontFamily="Segoe UI"
                                   FontSize="12"
                                   Foreground="#FF6E6E"
                                   Visibility="Collapsed"
                                   Margin="0,0,0,8"
                                   TextWrapping="Wrap"/>

                        <Button x:Name="StartButton"
                                Content="Start Chat"
                                Style="{StaticResource PrimaryButtonStyle}"
                                Height="44"
                                Click="StartButton_Click"/>
                    </StackPanel>
                </Border>
            </Grid>
        </Grid>

        <!-- SIDEBAR -->
        <Border Grid.Column="0"
                Background="{StaticResource SurfaceDark}"
                BorderBrush="{StaticResource BorderColor}"
                BorderThickness="0,0,1,0"
                Padding="14">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0" Margin="0,0,0,16">
                    <TextBlock Text="🛡 Security Center"
                               Style="{StaticResource SectionHeaderStyle}"/>
                    <TextBlock Text="Task manager, quiz, and activity log"
                               Style="{StaticResource HelperTextStyle}"/>
                </StackPanel>

                <Border Grid.Row="1"
                        Style="{StaticResource CardStyle}"
                        Margin="0,0,0,12"
                        Padding="12">
                    <StackPanel>
                        <TextBlock Text="Dashboard" Style="{StaticResource SectionHeaderStyle}" FontSize="14"/>
                        <TextBlock x:Name="DbStatusTextBlock"
                                   Text="Database: checking..."
                                   Style="{StaticResource HelperTextStyle}"
                                   TextWrapping="Wrap"
                                   Margin="0,4,0,8"/>
                        <Button Content="📋 View Tasks" Style="{StaticResource NavButtonStyle}" Click="ViewTasksButton_Click"/>
                        <Button Content="🎮 Start Quiz" Style="{StaticResource NavButtonStyle}" Click="StartQuizButton_Click"/>
                        <Button Content="📜 Activity Log" Style="{StaticResource NavButtonStyle}" Click="ActivityLogButton_Click"/>
                        <Button Content="↻ Refresh" Style="{StaticResource NavButtonStyle}" Click="RefreshTasksButton_Click"/>
                    </StackPanel>
                </Border>

                <Border Grid.Row="2"
                        Style="{StaticResource CardStyle}"
                        Padding="12">
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <StackPanel>
                            <TextBlock Text="Task Assistant" Style="{StaticResource SectionHeaderStyle}" FontSize="14"/>
                            <TextBox x:Name="TaskSearchTextBox"
                                     Style="{StaticResource InputBoxStyle}"
                                     Height="36"
                                     Margin="0,0,0,8"
                                     ToolTip="Search tasks"
                                     TextChanged="TaskSearchTextBox_TextChanged"/>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                <ComboBox x:Name="TaskFilterComboBox"
                                          Style="{StaticResource ComboBoxStyle}"
                                          Width="95"
                                          SelectedIndex="0"
                                          Margin="0,0,6,0"
                                          SelectionChanged="TaskFilterComboBox_SelectionChanged">
                                    <ComboBoxItem Content="All"/>
                                    <ComboBoxItem Content="Pending"/>
                                    <ComboBoxItem Content="Completed"/>
                                    <ComboBoxItem Content="Due Today"/>
                                    <ComboBoxItem Content="High Priority"/>
                                </ComboBox>
                                <ComboBox x:Name="TaskSortComboBox"
                                          Style="{StaticResource ComboBoxStyle}"
                                          Width="95"
                                          SelectedIndex="0"
                                          SelectionChanged="TaskSortComboBox_SelectionChanged">
                                    <ComboBoxItem Content="Newest first"/>
                                    <ComboBoxItem Content="Oldest first"/>
                                    <ComboBoxItem Content="Alphabetical"/>
                                    <ComboBoxItem Content="Due date"/>
                                </ComboBox>
                            </StackPanel>
                            <TextBox x:Name="NewTaskTitleTextBox"
                                     Style="{StaticResource InputBoxStyle}"
                                     Height="36"
                                     Margin="0,0,0,8"
                                     ToolTip="Task title"/>
                            <TextBox x:Name="NewTaskDescriptionTextBox"
                                     Style="{StaticResource InputBoxStyle}"
                                     Height="60"
                                     Margin="0,0,0,8"
                                     TextWrapping="Wrap"
                                     AcceptsReturn="True"
                                     VerticalScrollBarVisibility="Auto"
                                     ToolTip="Task description"/>
                            <DatePicker x:Name="NewTaskReminderDatePicker"
                                        Height="36"
                                        Margin="0,0,0,8"/>
                            <TextBox x:Name="NewTaskDueDateTextBox"
                                     Style="{StaticResource InputBoxStyle}"
                                     Height="36"
                                     Margin="0,0,0,8"
                                     ToolTip="Optional due date"/>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                <Button x:Name="AddTaskButton"
                                        Content="Add"
                                        Style="{StaticResource PrimaryButtonStyle}"
                                        Height="36"
                                        Width="80"
                                        Margin="0,0,6,0"
                                        Click="AddTaskButton_Click"/>
                                <Button x:Name="EditTaskButton"
                                        Content="Edit"
                                        Style="{StaticResource SecondaryButtonStyle}"
                                        Height="36"
                                        Width="70"
                                        Click="EditTaskButton_Click"/>
                            </StackPanel>
                            <DataGrid x:Name="TasksDataGrid"
                                      Style="{StaticResource DataGridStyle}"
                                      Height="220"
                                      SelectionMode="Single"
                                      SelectionUnit="FullRow"
                                      AutoGenerateColumns="False"
                                      CanUserAddRows="False"
                                      IsReadOnly="True"
                                      Margin="0,0,0,8">
                                <DataGrid.RowStyle>
                                    <Style TargetType="DataGridRow">
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsCompleted}" Value="True">
                                                <Setter Property="Background" Value="#2E3D2F"/>
                                                <Setter Property="Foreground" Value="#D7F5DC"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </DataGrid.RowStyle>
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="ID" Binding="{Binding Id}" Width="30"/>
                                    <DataGridTextColumn Header="Task" Binding="{Binding Title}" Width="110"/>
                                    <DataGridTextColumn Header="Priority" Binding="{Binding PriorityDisplay}" Width="70"/>
                                    <DataGridTextColumn Header="Status" Binding="{Binding StatusDisplay}" Width="70"/>
                                </DataGrid.Columns>
                            </DataGrid>
                            <StackPanel Orientation="Horizontal">
                                <Button x:Name="CompleteTaskButton"
                                        Content="Complete"
                                        Style="{StaticResource PrimaryButtonStyle}"
                                        Height="36"
                                        Width="90"
                                        Margin="0,0,6,0"
                                        Click="CompleteTaskButton_Click"/>
                                <Button x:Name="DeleteTaskButton"
                                        Content="Delete"
                                        Style="{StaticResource SecondaryButtonStyle}"
                                        Height="36"
                                        Width="80"
                                        Click="DeleteTaskButton_Click"/>
                            </StackPanel>
                        </StackPanel>
                    </ScrollViewer>
                </Border>

                <Border Grid.Row="3"
                        Style="{StaticResource CardStyle}"
                        Margin="0,12,0,0"
                        Padding="12">
                    <StackPanel>
                        <TextBlock Text="Quiz &amp; Insights" Style="{StaticResource SectionHeaderStyle}" FontSize="14"/>
                        <TextBlock x:Name="QuizStatusTextBlock"
                                   Text="No quiz in progress"
                                   Style="{StaticResource HelperTextStyle}"
                                   Margin="0,4,0,8"
                                   TextWrapping="Wrap"/>
                        <ProgressBar x:Name="QuizProgressBar"
                                     Height="10"
                                     Minimum="0"
                                     Maximum="1"
                                     Value="0"
                                     Margin="0,0,0,8"
                                     Foreground="{StaticResource SuccessGreen}"
                                     Background="#1A1A1A"/>
                        <Button Content="Start Quiz" Style="{StaticResource PrimaryButtonStyle}" Height="36" Margin="0,0,0,6" Click="StartQuizButton_Click"/>
                        <Button Content="Restart Quiz" Style="{StaticResource SecondaryButtonStyle}" Height="36" Margin="0,0,0,6" Click="RestartQuizButton_Click"/>
                        <Button Content="Export Tasks" Style="{StaticResource SecondaryButtonStyle}" Height="36" Click="ExportTasksButton_Click"/>
                    </StackPanel>
                </Border>
            </Grid>
        </Border>
    </Grid>
</Window>
